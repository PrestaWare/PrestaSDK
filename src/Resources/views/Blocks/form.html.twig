{% form_theme configureForm '@PrestaShop/Admin/TwigTemplateForm/prestashop_ui_kit.html.twig' %}

{% block content %}
  {{ form_start(configureForm) }}
  <div class="card">
    <h3 class="card-header">
      <i class="material-icons">settings</i> {{ title }}
    </h3>
    <div class="card-body">
      <div class="form-wrapper">
        {{ form_widget(configureForm) }}
      </div>
    </div>
    <div class="card-footer">
      <div class="d-flex justify-content-end">
        <button class="btn btn-primary float-right" id="save-button">
          {{ 'Save'|trans({}, 'Admin.Actions') }}
        </button>
      </div>
    </div>
  </div>
  {{ form_end(configureForm) }}
{% endblock %}