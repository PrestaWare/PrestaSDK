{% extends '@PrestaShop/Admin/layout.html.twig' %}

{% block stylesheets %}

{% endblock %}

{% block content %}

    <div id="pw-panel">

        <div class="pw-panel-header">
            {% if _positions.Header is defined %}
                {{ _positions.Header|raw }}
            {% endif %}
        </div>

        <div class="pw-panel-footer">

            {% if _positions.SideBar is defined %}
                <div class="pw-panel-sidebar col-md-3">
                    {{ _positions.SideBar|raw }}
                </div>
                {% set classContainer = 'col-md-9' %}
            {% else %}
                {% set classContainer = '' %}
            {% endif %}

            <div id="panelContainer" class="{{ classContainer }}">

                {% if _positions.TopContent is defined %}
                    {{ _positions.TopContent|raw }}
                {% endif %}

                {% include viewContent %}

                {% if _positions.BottomContent is defined %}
                    {{ _positions.BottomContent|raw }}
                {% endif %}

            </div>

        </div>

        <div class="pw-panel-footer">
            {% if _positions.Footer is defined %}
                {{ _positions.Footer|raw }}
            {% endif %}
        </div>

    </div>

{% endblock %}